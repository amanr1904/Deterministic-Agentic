      <aliases enabled='yes' />
      <column caption='Total Loans' datatype='integer' name='[Calculation_1872509954945024]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([loan_id])' />
      </column>
      <column caption='Total Funded Amount' datatype='real' name='[Calculation_1872509955170305]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([loan_amount])' />
      </column>
      <column caption='Default Flag' datatype='integer' name='[Calculation_1872509959208964]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [loan_status] = &quot;Charged Off&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Default Rate' datatype='real' name='[Calculation_1872509959417861]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1872509959208964]) / COUNT([loan_id])' />
      </column>
      <column caption='Default Risk Category' datatype='string' name='[Calculation_1872509959573510]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1872509959417861] &gt; 0.20 THEN &quot;High Risk&quot;&#13;&#10;ELSE &quot;Safe&quot;&#13;&#10;END' />
      </column>
      <column caption='YoY Growth %' datatype='real' name='[Calculation_1872509966282760]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(COUNT([loan_id]) - LOOKUP(COUNT([loan_id]), -1))&#13;&#10;/&#13;&#10;LOOKUP(COUNT([loan_id]), -1)'>
          <table-calc ordering-field='[federated.18e8p121a6tl721befxy016u4rxt].[issue_year]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='Highlight Peak Year' datatype='string' name='[Calculation_1872509966647305]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF COUNT([loan_id]) = WINDOW_MAX(COUNT([loan_id]))&#13;&#10;THEN &quot;Peak&quot;&#13;&#10;ELSE &quot;Normal&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='State Rank' datatype='integer' name='[Calculation_1872509972021258]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([loan_amount]), &apos;desc&apos;)'>
          <table-calc ordering-field='[federated.18e8p121a6tl721befxy016u4rxt].[state]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='Top N Filter' datatype='boolean' name='[Calculation_1872509973000203]' role='measure' type='nominal'>
        <calculation class='tableau' formula='INDEX() &lt;= [Parameters].[Parameter 1]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
