    <dashboard name='Launch Report Dashboard'>
      <repository-location derived-from='https://tableau.harley-davidson.com/workbooks/January2021LaunchDashboard/LaunchReportDashboard?rev=' id='LaunchReportDashboard' path='/workbooks/2021Q3LaunchDashboard' revision='' />
      <style />
      <size maxheight='1100' maxwidth='1500' minheight='1100' minwidth='1500' sizing-mode='fixed' />
      <datasources>
        <datasource name='Parameters' />
      </datasources>
      <datasource-dependencies datasource='Parameters'>
        <column caption='Rows Displayed' datatype='integer' datatype-customized='true' name='[Rank Sort Measure (copy)]' param-domain-type='list' role='measure' type='quantitative' value='10'>
          <calculation class='tableau' formula='10' />
          <aliases>
            <alias key='10000' value='All' />
          </aliases>
          <members>
            <member value='5' />
            <member value='10' />
            <member value='20' />
            <member value='50' />
            <member alias='All' value='10000' />
          </members>
        </column>
        <column caption='Rank Sort Measure' datatype='string' name='[Total Orders Parameter]' param-domain-type='list' role='measure' type='nominal' value='&quot;Order $ (Decending)&quot;'>
          <calculation class='tableau' formula='&quot;Order $ (Decending)&quot;' />
          <members>
            <member value='&quot;Order $ (Decending)&quot;' />
            <member value='&quot;Order Units (Decending)&quot;' />
            <member value='&quot;Order $ (Accending)&quot;' />
            <member value='&quot;Order Units (Accending)&quot;' />
          </members>
        </column>
      </datasource-dependencies>
