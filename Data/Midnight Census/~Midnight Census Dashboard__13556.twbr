      <column caption='User Defined Census Count' datatype='integer' name='[Calculation_2234066952297496576]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[End Date (copy)]&#13;&#10;    WHEN &apos;(All)&apos; THEN SUM([Census Count])&#13;&#10;    WHEN &apos;Adults&apos; THEN SUM([Census Count Adults])&#13;&#10;    WHEN &apos;Peds&apos; THEN SUM([Census Count Peds])&#13;&#10;END' />
      </column>
      <column caption='Date Range Filter' datatype='boolean' name='[Calculation_2234066952299909123]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Census Date] &gt;= [Parameters].[Parameter 3] AND [Census Date] &lt;= [Parameters].[Start Date (copy)_305681891901829120]' />
      </column>
      <column caption='Start Month Contains Partial Data?' datatype='integer' name='[Calculation_2234066952300421124]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF&#13;&#10;YEAR(MAX([Census Date])) = YEAR(MAX([Parameters].[Parameter 3]))&#13;&#10;AND MONTH(MAX([Census Date])) = MONTH(MAX([Parameters].[Parameter 3]))&#13;&#10;AND MIN([Parameters].[Parameter 3]) &lt;&gt; DATE(STR(YEAR(WINDOW_MIN(MIN([Census Date]))))+&apos;-&apos;+STR(MONTH(WINDOW_MIN(MIN([Census Date]))))+&apos;-01&apos;)&#13;&#10;THEN 1 ELSE 0 END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='End Month Contains Partial Data?' datatype='integer' name='[Calculation_2234066952300756997]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF MONTH(MAX([Parameters].[Start Date (copy)_305681891901829120])) = 12 THEN&#13;&#10;    IF YEAR(MAX([Census Date])) = YEAR(MAX([Parameters].[Start Date (copy)_305681891901829120]))&#13;&#10;    AND MONTH(MAX([Census Date])) = MONTH(MAX([Parameters].[Start Date (copy)_305681891901829120]))&#13;&#10;    AND MAX([Parameters].[Start Date (copy)_305681891901829120]) &lt;&gt; DATEADD(&apos;day&apos;, -1, DATE(STR(YEAR(WINDOW_MAX(MAX([Census Date])))+1)+&apos;-&apos;+STR(MONTH(DATEADD(&apos;month&apos;, 1, WINDOW_MAX(MAX([Census Date])))))+&apos;-01&apos;))&#13;&#10;    THEN 1 ELSE 0 END&#13;&#10;ELSEIF YEAR(MAX([Census Date])) = YEAR(MAX([Parameters].[Start Date (copy)_305681891901829120]))&#13;&#10;    AND MONTH(MAX([Census Date])) = MONTH(MAX([Parameters].[Start Date (copy)_305681891901829120]))&#13;&#10;    AND MAX([Parameters].[Start Date (copy)_305681891901829120]) &lt;&gt; DATEADD(&apos;day&apos;, -1, DATE(STR(YEAR(WINDOW_MAX(MAX([Census Date]))))+&apos;-&apos;+STR(MONTH(DATEADD(&apos;month&apos;, 1, WINDOW_MAX(MAX([Census Date])))))+&apos;-01&apos;))&#13;&#10;    THEN 1 ELSE 0 &#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Default Start Date' datatype='date' name='[Calculation_2234066952304320524]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF MONTH(TODAY()) &gt;= 7 OR MONTH(TODAY()) &lt;= 9 &#13;&#10;THEN DATE(STR(YEAR(TODAY())) + &apos;-01-01&apos;)&#13;&#10;ELSE&#13;&#10;    IF MONTH(TODAY()) &lt; 7 THEN&#13;&#10;        DATE(STR(YEAR(TODAY())-1) + &apos;-07-01&apos;)&#13;&#10;    ELSE DATE(STR(YEAR(TODAY())) + &apos;-07-01&apos;)&#13;&#10;    END&#13;&#10;END' />
      </column>
      <column caption='Default End Date' datatype='date' name='[Calculation_2234066952304459789]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='TODAY()-1' />
      </column>
      <column caption='Date agg_Monthly' datatype='string' name='[Calculation_2234066952309055503]' role='dimension' type='nominal'>
