            <column caption='End Date' datatype='date' default-format='*m/d/yyyy' default-value-field='[federated.09go31s1b3pn2k1ezewf3027s71v].[Calculation_2234066952304459789]' name='[Start Date (copy)_305681891901829120]' param-domain-type='range' role='measure' source-field='[federated.09go31s1b3pn2k1ezewf3027s71v].[Census Date]' type='quantitative' value='#2026-06-07#'>
              <calculation class='tableau' formula='#2026-06-07#' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.09go31s1b3pn2k1ezewf3027s71v'>
            <column caption='Date Range Filter' datatype='boolean' name='[Calculation_2234066952299909123]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Census Date] &gt;= [Parameters].[Parameter 3] AND [Census Date] &lt;= [Parameters].[Start Date (copy)_305681891901829120]' />
            </column>
            <column caption='Default Start Date' datatype='date' name='[Calculation_2234066952304320524]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='IF MONTH(TODAY()) &gt;= 7 OR MONTH(TODAY()) &lt;= 9 &#13;&#10;THEN DATE(STR(YEAR(TODAY())) + &apos;-01-01&apos;)&#13;&#10;ELSE&#13;&#10;    IF MONTH(TODAY()) &lt; 7 THEN&#13;&#10;        DATE(STR(YEAR(TODAY())-1) + &apos;-07-01&apos;)&#13;&#10;    ELSE DATE(STR(YEAR(TODAY())) + &apos;-07-01&apos;)&#13;&#10;    END&#13;&#10;END' />
            </column>
            <column caption='Default End Date' datatype='date' name='[Calculation_2234066952304459789]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='TODAY()-1' />
            </column>
            <column caption='Partial Months in View?' datatype='string' name='[Calculation_2234066952314589212]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF DAY([Parameters].[Parameter 3]) != 1&#13;&#10;    OR DAY(DATEADD(&apos;day&apos;,1,[Parameters].[Start Date (copy)_305681891901829120])) != 1&#13;&#10;THEN &quot;**Partial months are displayed in GRAY**&quot; ELSE &quot;&quot; END' />
            </column>
            <column caption='Census Date1' datatype='date' name='[Census Date]' role='dimension' type='ordinal' />
