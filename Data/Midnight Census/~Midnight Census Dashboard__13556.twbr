            </column>
            <column caption='Start Month Contains Partial Data?' datatype='integer' name='[Calculation_2234066952300421124]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF&#13;&#10;YEAR(MAX([Census Date])) = YEAR(MAX([Parameters].[Parameter 3]))&#13;&#10;AND MONTH(MAX([Census Date])) = MONTH(MAX([Parameters].[Parameter 3]))&#13;&#10;AND MIN([Parameters].[Parameter 3]) &lt;&gt; DATE(STR(YEAR(WINDOW_MIN(MIN([Census Date]))))+&apos;-&apos;+STR(MONTH(WINDOW_MIN(MIN([Census Date]))))+&apos;-01&apos;)&#13;&#10;THEN 1 ELSE 0 END'>
