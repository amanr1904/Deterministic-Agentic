  "measures": [
    {
      "table": "netflix_titles",
      "name": "Title Count",
      "dax": "DISTINCTCOUNT('netflix_titles'[show_id])",
      "formatString": "#,0",
      "displayFolder": "Counts",
      "description": "Distinct count of show_id — core catalog metric.",
      "source": "llm"
    },
    {
      "table": "netflix_titles",
      "name": "Movies Count",
      "dax": "CALCULATE([Title Count], 'netflix_titles'[type] = \"Movie\")",
      "formatString": "#,0",
      "displayFolder": "Counts",
      "description": "Title Count filtered to type = Movie.",
      "source": "llm"
    },
    {
      "table": "netflix_titles",
      "name": "TV Shows Count",
      "dax": "CALCULATE([Title Count], 'netflix_titles'[type] = \"TV Show\")",
      "formatString": "#,0",
      "displayFolder": "Counts",
      "description": "Title Count filtered to type = TV Show.",
      "source": "llm"
    },
    {
      "table": "netflix_titles",
      "name": "Genre Rank",
      "dax": "RANKX(ALL('netflix_titles'[listed_in]), [Title Count], , DESC, Dense)",
      "formatString": "#,0",
      "displayFolder": "Report Helpers",
      "description": "Ranks listed_in by Title Count; Top 10 Genre bar filters Genre Rank <= 10.",
      "source": "llm"
    }
  ],
