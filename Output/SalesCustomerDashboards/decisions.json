  "measures": [
    {
      "table": "Orders",
      "name": "Total Sales",
      "dax": "SUM(Orders[Sales])",
      "formatString": "#,0.00",
      "displayFolder": "Sales",
      "description": "Total Sales amount.",
      "source": "llm"
    },
    {
      "table": "Orders",
      "name": "Total Profit",
      "dax": "SUM(Orders[Profit])",
      "formatString": "#,0.00",
      "displayFolder": "Profit",
      "description": "Total Profit amount.",
      "source": "llm"
    },
    {
      "table": "Orders",
