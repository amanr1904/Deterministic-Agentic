    },
    {
      "table": "Orders",
      "name": "% Diff Sales per Customers",
      "dax": "DIVIDE([CY Sales per Customer] - [PY Sales per Customer], [PY Sales per Customer])",
      "formatString": "0.0%;-0.0%;0.0%",
      "displayFolder": "Variance",
      "description": "YoY Sales per Customer % difference.",
      "source": "llm"
    },
    {
      "table": "Orders",
      "name": "KPI CY Less PY",
      "dax": "IF([CY Sales] < [PY Sales], \"⬤\", \"\")",
