      "dax": "SUM(Orders[Quantity])",
      "formatString": "#,0",
      "displayFolder": "Quantity",
      "description": "Total Quantity sold.",
      "source": "llm"
    },
    {
      "table": "Orders",
      "name": "Total Orders",
      "dax": "DISTINCTCOUNT(Orders[Order ID])",
      "formatString": "#,0",
      "displayFolder": "Orders",
      "description": "Count of distinct orders.",
      "source": "llm"
    },
    {
      "table": "Orders",
      "name": "Total Customers",
      "dax": "DISTINCTCOUNT(Orders[Customer ID])",
      "formatString": "#,0",
      "displayFolder": "Customers",
      "description": "Count of distinct customers.",
      "source": "llm"
    },
    {
      "table": "Orders",
      "name": "Sales per Customer",
      "dax": "DIVIDE([Total Sales], [Total Customers])",
      "formatString": "#,0.00",
      "displayFolder": "Sales",
      "description": "Average Sales per distinct customer.",
      "source": "llm"
    },
    {
      "table": "Orders",
      "name": "CY Sales",
      "dax": "CALCULATE([Total Sales], YEAR(Orders[Order Date]) = SELECTEDVALUE(SelectYear[Year], 2023))",
      "formatString": "#,0.00",
      "displayFolder": "CY",
      "description": "Current Year Sales filtered by SelectYear parameter.",
      "source": "llm"
    },
    {
      "table": "Orders",
      "name": "PY Sales",
      "dax": "CALCULATE([Total Sales], YEAR(Orders[Order Date]) = SELECTEDVALUE(SelectYear[Year], 2023) - 1)",
      "formatString": "#,0.00",
      "displayFolder": "PY",
      "description": "Previous Year Sales.",
      "source": "llm"
    },
