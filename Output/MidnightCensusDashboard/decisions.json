{
  "modelName": "MidnightCensusDashboard",
  "tableStrategy": "single-flat",
  "tables": [
    {
      "name": "Midnight_Census_Template",
      "role": "fact",
      "sourceDatasource": "Midnight_Census_Template",
      "sourceFile": "Midnight_Census_Template.csv"
    },
    {
      "name": "Filter Adults Peds",
      "role": "param",
      "datatable": {
        "columns": [{ "name": "Filter Adults Peds", "dataType": "string", "type": "string" }],
        "rows": [["(All)"], ["Adults"], ["Peds"]]
      }
    },
    {
      "name": "View",
      "role": "param",
      "datatable": {
        "columns": [{ "name": "View", "dataType": "string", "type": "string" }],
        "rows": [["Bar Chart"], ["Data Table"]]
      }
    }
  ],
  "relationships": [],
  "measures": [
    {
      "name": "Total Census Count",
      "table": "Midnight_Census_Template",
      "dax": "SUM('Midnight_Census_Template'[Census Count])",
      "formatString": "#,0",
      "displayFolder": "Census",
      "description": "Total midnight census (patient days) across all units.",
      "source": "base"
    },
    {
      "name": "Adults Census Count",
      "table": "Midnight_Census_Template",
      "dax": "SUM('Midnight_Census_Template'[Census Count Adults])",
      "formatString": "#,0",
      "displayFolder": "Census",
      "description": "Midnight census for adult patients.",
      "source": "base"
    },
    {
      "name": "Peds Census Count",
      "table": "Midnight_Census_Template",
      "dax": "SUM('Midnight_Census_Template'[Census Count Peds])",
      "formatString": "#,0",
      "displayFolder": "Census",
      "description": "Midnight census for pediatric patients.",
      "source": "base"
    },
    {
      "name": "User Defined Census Count",
      "table": "Midnight_Census_Template",
      "dax": "VAR _sel = SELECTEDVALUE('Filter Adults Peds'[Filter Adults Peds], \"(All)\")\nRETURN\n    SWITCH(\n        _sel,\n        \"Adults\", [Adults Census Count],\n        \"Peds\", [Peds Census Count],\n        [Total Census Count]\n    )",
      "formatString": "#,0",
      "displayFolder": "Census",
      "description": "Census driven by the Filter Adults/Peds parameter selection (mirrors the Tableau CASE expression).",
      "source": "tableau-calc"
    },
    {
      "name": "Encounter Count",
      "table": "Midnight_Census_Template",
      "dax": "DISTINCTCOUNT('Midnight_Census_Template'[Encounter CSN])",
      "formatString": "#,0",
      "displayFolder": "Census",
      "description": "Distinct count of patient encounters.",
      "source": "base"
    },
    {
      "name": "Start Month Contains Partial Data?",
      "table": "Midnight_Census_Template",
      "dax": "IF(DAY(MIN('Midnight_Census_Template'[Census Date])) <> 1, 1, 0)",
      "formatString": "0",
      "displayFolder": "Partial Data Flags",
      "description": "Best-effort port of the Tableau WINDOW_MIN flag: 1 when the first visible month starts after the 1st (partial month).",
      "source": "tableau-calc"
    },
    {
      "name": "End Month Contains Partial Data?",
      "table": "Midnight_Census_Template",
      "dax": "VAR _d = MAX('Midnight_Census_Template'[Census Date])\nRETURN IF(_d <> EOMONTH(_d, 0), 1, 0)",
      "formatString": "0",
      "displayFolder": "Partial Data Flags",
      "description": "Best-effort port of the Tableau WINDOW_MAX flag: 1 when the last visible month ends before month-end (partial month).",
      "source": "tableau-calc"
    }
  ],
  "calculatedColumns": [],
  "visualDecisions": [],
  "fieldParameters": [
    {
      "name": "Date Agg Level",
      "appliesTo": ["Monthly bar", "Daily bar"],
      "axis": "category",
      "fields": [
        { "label": "Monthly", "table": "Midnight_Census_Template", "column": "Census Date (Month)" },
        { "label": "Daily", "table": "Midnight_Census_Template", "column": "Census Date" }
      ]
    }
  ]
}
